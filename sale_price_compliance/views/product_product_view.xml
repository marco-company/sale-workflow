<odoo>
    <record id="product_variant_easy_edit_view" model="ir.ui.view">
        <field name="name">product.product.view.form.easy</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='pricing']" position="after">
                <group
                    name="group_sale_price_compliance_threshold"
                    string="Sale Price Compliance Thresholds"
                    groups="sale_price_compliance.price_compliance_threshold_manager"
                >
                    <field
                        name="use_price_compliance_threshold"
                        widget="boolean_toggle"
                    />
                    <field
                        name="price_compliance_threshold_t1"
                        widget="percentage"
                        attrs="{'invisible': [('use_price_compliance_threshold', '=', False)]}"
                        class="w-25"
                    />
                    <field
                        name="price_compliance_threshold_t2"
                        widget="percentage"
                        attrs="{'invisible': [('use_price_compliance_threshold', '=', False)]}"
                        class="w-25"
                    />
                    <field
                        name="price_compliance_threshold_t3"
                        widget="percentage"
                        attrs="{'invisible': [('use_price_compliance_threshold', '=', False)]}"
                        class="w-25"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
